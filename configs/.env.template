# Personal Voice Capsule - Environment Configuration
# ============================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to Git (it's in .gitignore)
# ============================================

# API Keys
# ============================================

# Gemini API Key (Required for ASR transcription)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: OpenAI API Key (for AI enhancement - Level 3)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Optional: Anthropic Claude API Key (alternative for AI enhancement)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# Paths Configuration
# ============================================

# Obsidian Vault Path (Required)
# Example Mac: /Users/harvad/Documents/Obsidian/Personal-OS
# Example Windows: C:\Users\Harvad\Documents\Obsidian\Personal-OS
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# DJI Mic 3 Mount Path (Auto-detected on Mac, manual on Windows)
# Mac default: /Volumes/DJI MIC 3
# Windows example: E:\
DJI_MIC_PATH=/Volumes/DJI MIC 3

# Processing Directory (where WAV files are temporarily stored)
PROCESSING_DIR=~/.personal-voice-capsule/processing

# Backup Directory (optional, for keeping original recordings)
BACKUP_DIR=~/.personal-voice-capsule/backups

# ============================================
# Transcription Settings
# ============================================

# ASR Provider (gemini, openai-whisper, local-whisper)
ASR_PROVIDER=gemini

# Gemini Model Selection
# Options: gemini-1.5-flash, gemini-1.5-pro, gemini-2.0-flash-exp
# Recommendation: gemini-1.5-flash (fast & cheap)
GEMINI_MODEL=gemini-1.5-flash

# Language Settings
# Options: auto (auto-detect), en, zh, sv, es, fr, de, ja, ko
TRANSCRIPTION_LANGUAGE=auto

# Audio Quality Settings
# Options: low, medium, high
AUDIO_QUALITY=high

# ============================================
# Obsidian Integration Settings
# ============================================

# Inbox Folder (where new notes are saved)
OBSIDIAN_INBOX_FOLDER=00-inbox

# Template to use for voice notes
OBSIDIAN_TEMPLATE=voice-note-template

# Auto-organize notes (true/false)
# If true, AI will categorize and move notes to appropriate folders
AUTO_ORGANIZE=false

# ============================================
# Automation Settings
# ============================================

# Watch Mode (continuously monitor for new recordings)
WATCH_MODE=true

# Processing Interval (seconds between checks)
PROCESS_INTERVAL=30

# Auto-process on connect (start processing when DJI Mic 3 is detected)
AUTO_PROCESS_ON_CONNECT=true

# Delete WAV files after successful processing (true/false)
DELETE_AFTER_PROCESSING=false

# Backup originals before processing (true/false)
BACKUP_ORIGINALS=true

# ============================================
# AI Enhancement Settings (Level 3 - Optional)
# ============================================

# Enable AI enhancement (true/false)
AI_ENHANCEMENT_ENABLED=false

# AI Provider for enhancement (openai, anthropic, gemini)
AI_ENHANCEMENT_PROVIDER=openai

# AI Model for enhancement
# OpenAI: gpt-4o, gpt-4-turbo, gpt-3.5-turbo
# Anthropic: claude-3-5-sonnet-20241022, claude-3-opus-20240229
# Gemini: gemini-1.5-pro, gemini-2.0-flash-exp
AI_ENHANCEMENT_MODEL=gpt-4o

# Auto-categorize notes (true/false)
AUTO_CATEGORIZE=false

# Auto-tag notes (true/false)
AUTO_TAG=false

# Auto-link to existing notes (true/false)
AUTO_LINK=false

# Extract key concepts (true/false)
EXTRACT_CONCEPTS=false

# ============================================
# NotebookLM Integration (Optional)
# ============================================

# Enable NotebookLM sync (true/false)
NOTEBOOKLM_ENABLED=false

# NotebookLM credentials file path
NOTEBOOKLM_CREDENTIALS_PATH=~/.config/notebooklm/credentials.json

# NotebookLM Notebook ID
NOTEBOOKLM_NOTEBOOK_ID=

# ============================================
# Notification Settings
# ============================================

# Enable desktop notifications (true/false)
NOTIFICATIONS_ENABLED=true

# Notification sound (true/false)
NOTIFICATION_SOUND=true

# ============================================
# Logging & Debugging
# ============================================

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Log File Path
LOG_FILE=~/.personal-voice-capsule/logs/app.log

# Keep logs for (days)
LOG_RETENTION_DAYS=30

# ============================================
# Advanced Settings
# ============================================

# Timezone (for timestamp formatting)
TIMEZONE=Europe/Stockholm

# Date Format (for note filenames)
# Example: %Y-%m-%d = 2024-01-15
DATE_FORMAT=%Y-%m-%d

# Time Format (for timestamps)
# Example: %H:%M:%S = 14:30:00
TIME_FORMAT=%H:%M:%S

# Max concurrent transcriptions
MAX_CONCURRENT_JOBS=3

# Retry failed transcriptions (number of attempts)
MAX_RETRIES=3

# ============================================
# Privacy & Security
# ============================================

# Use local processing only (no cloud APIs)
LOCAL_ONLY_MODE=false

# Encrypt backups (requires additional setup)
ENCRYPT_BACKUPS=false

# Anonymous usage statistics (helps improve the project)
ANONYMOUS_STATS=true

# ============================================
# End of Configuration
# ============================================

# Quick Setup Checklist:
# [ ] 1. Copy this file to .env
# [ ] 2. Add your GEMINI_API_KEY
# [ ] 3. Set your OBSIDIAN_VAULT_PATH
# [ ] 4. Adjust DJI_MIC_PATH if needed (usually auto-detected)
# [ ] 5. Run: ./scripts/mac/install.sh
# [ ] 6. Test with: python scripts/python/transcribe.py --test
